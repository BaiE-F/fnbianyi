{
  "description": "MiniLang 词法规则库",
  "keywords": {
    "int": "INT",
    "float": "FLOAT",
    "string": "STRING",
    "if": "IF",
    "else": "ELSE",
    "while": "WHILE",
    "for": "FOR",
    "print": "PRINT",
    "printn": "PRINTN",
    "input": "INPUT",
    "write": "WRITE",
    "return": "RETURN",
    "break": "BREAK",
    "continue": "CONTINUE"
  },
  "operators": {
    "==": "EQ",
    "!=": "NE",
    "<=": "LE",
    ">=": "GE",
    "&&": "AND",
    "||": "OR",
    "+": "PLUS",
    "-": "MINUS",
    "*": "STAR",
    "/": "SLASH",
    "=": "ASSIGN",
    "<": "LT",
    ">": "GT",
    "!": "NOT",
    "(": "LPAREN",
    ")": "RPAREN",
    "{": "LBRACE",
    "}": "RBRACE",
    "[": "LBRACKET",
    "]": "RBRACKET",
    ";": "SEMI",
    ",": "COMMA"
  },
  "patterns": [
    {"name": "STRING_LIT", "regex": "\"([^\"\\\\]|\\\\.)*\""},
    {"name": "FLOAT_LIT", "regex": "\\d+\\.\\d+"},
    {"name": "INT_LIT", "regex": "\\d+"},
    {"name": "IDENT", "regex": "[a-zA-Z_][a-zA-Z0-9_]*"},
    {"name": "WHITESPACE", "regex": "[ \\t\\r\\n]+", "skip": true},
    {"name": "COMMENT", "regex": "//[^\\n]*", "skip": true}
  ]
}
