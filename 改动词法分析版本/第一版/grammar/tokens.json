{
  "description": "MiniLang 词法规则库 — 字符集 + NFA/DFA",
  "charsets": {
    "digit": "0123456789",
    "letter": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ",
    "blank": " \t\r\n",
    "nonl_blank": " \t\r",
    "pt": ".",
    "cjk": "",
    "symbol": ".,:;!?+-*/=%<>()[]{}'，。：；！？（）【】《》、@#$%^&|~`"
  },
  "keywords": {
    "int": "INT",
    "float": "FLOAT",
    "string": "STRING",
    "void": "VOID",
    "if": "IF",
    "else": "ELSE",
    "while": "WHILE",
    "for": "FOR",
    "print": "PRINT",
    "printn": "PRINTN",
    "input": "INPUT",
    "write": "WRITE",
    "return": "RETURN",
    "break": "BREAK",
    "continue": "CONTINUE"
  },
  "operators": {
    "==": "EQ",
    "!=": "NE",
    "<=": "LE",
    ">=": "GE",
    "&&": "AND",
    "||": "OR",
    "+": "PLUS",
    "-": "MINUS",
    "*": "STAR",
    "/": "SLASH",
    "=": "ASSIGN",
    "<": "LT",
    ">": "GT",
    "!": "NOT",
    "(": "LPAREN",
    ")": "RPAREN",
    "{": "LBRACE",
    "}": "RBRACE",
    "[": "LBRACKET",
    "]": "RBRACKET",
    ";": "SEMI",
    ",": "COMMA"
  },
  "patterns": [
    {"name": "COMMENT", "regex": "//(cjk|letter|digit|nonl_blank|_|symbol)*", "skip": true},
    {"name": "STRING_LIT", "regex": "\"(cjk|letter|digit|blank|_|symbol)*\""},
    {"name": "FLOAT_LIT", "regex": "digit+(pt)(digit+)"},
    {"name": "INT_LIT", "regex": "digit+"},
    {"name": "IDENT", "regex": "(letter|_)((letter|digit|_))*"},
    {"name": "WHITESPACE", "regex": "blank+", "skip": true}
  ]
}
